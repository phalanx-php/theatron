#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once dirname(__DIR__) . '/vendor/autoload_runtime.php';

use Phalanx\Application;
use Phalanx\Scope\ExecutionScope;
use Phalanx\Theatron\Theatron;
use Phalanx\Theatron\Template\TheatronTemplate;

return static function (array $context): \Closure {
    return static function () use ($context): int {
        $builder = TheatronTemplate::configure(Theatron::app($context));
        $theatronApp = $builder->build();

        Application::starting($context)
            ->providers($builder->serviceBundle(), ...$builder->registeredServiceBundles())
            ->compile()
            ->run(static function (ExecutionScope $scope) use ($theatronApp): void {
                $theatronApp->start($scope);
            });

        return 0;
    };
};
